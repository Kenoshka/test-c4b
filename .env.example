# ─── Docker image ────────────────────────────────────────────────────────────
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ─── Paths (relative to this project folder, Docker Desktop resolves them) ───
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./config/workspace
OPENCLAW_AUTH_PROFILE_SECRET_DIR=./config/auth

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Google Gemini API ключ (из aistudio.google.com → Get API key)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# ─── Gateway auth (required when bind=lan) ───────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=YOUR_GATEWAY_TOKEN_HERE

# ─── Optional ─────────────────────────────────────────────────────────────────
OPENCLAW_TZ=Europe/Moscow
