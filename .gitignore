# Secrets — never commit
.env
config/openclaw.json
config/auth/

# Runtime data generated by OpenClaw — ignore content, keep structure
config/logs/
config/state/*
!config/state/.gitkeep
config/agents/**
!config/agents/main/.gitkeep
!config/agents/main/sessions/.gitkeep
config/workspace/
config/plugin-skills/
config/completions/
config/identity/
config/update-check.json
config/workspace-attestations/
config/*.bak
config/*.bak.*
config/*.last-good
